{
  "name": "ledgerland-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "compile:solidity": "hardhat compile",
    "node:chain": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.cjs --network localhost",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "ethers": "^6.13.5",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.13.2",
    "pdfkit": "^0.15.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/pdfkit": "^0.13.9",
    "@types/node": "^22.14.0",
    "@types/supertest": "^6.0.3",
    "hardhat": "^2.22.18",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "tsx": "^4.19.3",
    "typescript": "~5.8.3"
  }
}
